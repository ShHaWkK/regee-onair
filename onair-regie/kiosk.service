[Unit]
Description=Kiosk
After=graphical.target network-online.target docker-compose-onair.service
Wants=docker-compose-onair.service

[Service]
User=companion
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/companion/.Xauthority
Type=simple
ExecStart=/home/companion/regee-onair/onair-regie/kiosk.sh
Restart=always
RestartSec=5

[Install]
WantedBy=graphical.target

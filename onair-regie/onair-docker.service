[Unit]
Description=Docker OnAIR
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=oneshot
User=companion
Group=docker
WorkingDirectory=/home/companion/regee-onair/onair-regie
ExecStart=/usr/bin/docker-compose up -d
ExecStop=/usr/bin/docker-compose down
RemainAfterExit=yes
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target

# Token secret pour protéger les endpoints /api/on et /api/off
# Générer avec : openssl rand -hex 32
ONAIR_TOKEN=change-me-with-a-strong-secret

# Upstash Redis  créer un compte sur https://console.upstash.com
# Créer une base Redis (Free tier ou Pay-as-you-go) puis copier les valeurs ici
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
